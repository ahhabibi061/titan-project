# Copy this file to .env and fill in your values.
# Supabase: Dashboard → Project Settings → API
# Stripe:   Dashboard → Products → (see STRIPE_SETUP.md)

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe price IDs (publishable — safe to expose in browser)
VITE_STRIPE_PRICE_PRO_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX
VITE_STRIPE_PRICE_ELITE_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX

# USDA FoodData Central API — https://fdc.nal.usda.gov/api-guide.html
VITE_USDA_API_KEY=your-usda-api-key-here

# FatSecret Platform API — https://platform.fatsecret.com/api/
# OAuth 2.0 client credentials (basic scope covers food search)
VITE_FATSECRET_CLIENT_ID=your-fatsecret-client-id
VITE_FATSECRET_CLIENT_SECRET=your-fatsecret-client-secret
