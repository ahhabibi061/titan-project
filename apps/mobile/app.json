{
  "expo": {
    "name": "Titan",
    "slug": "titan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "titan",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0908"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.titan.app"
    },
    "android": {
      "package": "com.titan.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0908"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-font",
      ["expo-image-picker", {
        "photosPermission": "Allow IronLab to access your photos for progress tracking."
      }]
    ]
  }
}
